menu "Cellular Connect Example"

    config ML_EXAMPLE_TARGET_PEER_IP
        string "Target Peer VPN IP (for sending)"
        default ""
        help
            VPN IP of the peer to send "hello" messages to (e.g., "100.103.181.24").
            Leave empty to only receive (no outgoing messages).

    choice ML_EXAMPLE_TRANSPORT
        prompt "Transport protocol"
        default ML_EXAMPLE_UDP
        help
            Choose UDP or TCP for sending data to the target peer.
            UDP: Uses microlink_udp_send (fire-and-forget, low overhead).
            TCP: Uses microlink_tcp_connect/send (reliable, connection-oriented).

        config ML_EXAMPLE_UDP
            bool "UDP"
        config ML_EXAMPLE_TCP
            bool "TCP"
    endchoice

    config ML_EXAMPLE_TCP_PORT
        int "TCP destination port"
        default 5055
        depends on ML_EXAMPLE_TCP
        help
            TCP port on the target peer to connect to.
            Common: 5055 (Traccar OsmAnd), 80 (HTTP), 1883 (MQTT).

endmenu
