# MicroLink Credentials — DO NOT commit this file!
#
# 1. Copy this file to sdkconfig.credentials:
#      cp sdkconfig.credentials.example sdkconfig.credentials
# 2. Edit sdkconfig.credentials with your real values
# 3. Run: idf.py build
#
# Or set interactively: idf.py menuconfig → MicroLink V2 → Credentials

CONFIG_ML_TAILSCALE_AUTH_KEY="tskey-auth-XXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
CONFIG_ML_CELLULAR_SIM_PIN="0000"
CONFIG_ML_CELLULAR_APN="your-apn"
