# Failover Connect Credentials — DO NOT commit this file!
#
# 1. Copy: cp sdkconfig.credentials.example sdkconfig.credentials
# 2. Edit with your values
# 3. Build: idf.py build

CONFIG_ML_WIFI_SSID="your-wifi-ssid"
CONFIG_ML_WIFI_PASSWORD="your-wifi-password"
CONFIG_ML_TAILSCALE_AUTH_KEY="tskey-auth-XXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
CONFIG_ML_CELLULAR_SIM_PIN="0000"
CONFIG_ML_CELLULAR_APN="your-apn"
